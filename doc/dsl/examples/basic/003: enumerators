import io.

TEST_FLAGS: flags
{
    flag1,
    flag2,
    flag3
}.

TEST_MASK: bitmask
{
    mask1,
    mask2,
    mask3,
    mask4
}.

flagTest: flags TEST_FLAGS = flag1.
maskTest: bitmask TEST_MASK = mask1 | mask3.

if flagTest = TEST_FLAGS-flag1 then
    io-print "Flag1 selected.".
otherwise
    io-print "Other flag selected.".
converge.

if maskTest & TEST_MASK-mask1 != 0 then
    io-print "Mask1 selected!".
otherwise
    io-print "Mask1 not present.".
converge.

